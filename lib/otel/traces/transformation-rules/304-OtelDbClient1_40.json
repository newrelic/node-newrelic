{
  "name": "OtelDbClient1_40",
  "type": "db",
  "matcher": {
    "required_span_kinds": [
      "client"
    ],
    "required_attribute_keys": [
      "db.system.name",
      "server.address",
      "server.port"
    ]
  },
  "attributes": [
    {
      "key": "db.system.name",
      "target": "segment",
      "name": "product"
    },
    {
      "key": "db.namespace",
      "target": "segment",
      "name": "database_name"
    },
    {
      "key": "server.address",
      "target": "segment",
      "name": "host"
    },
    {
      "key": "server.port",
      "target": "segment",
      "name": "port_path_or_id"
    }
  ],
  "segment": {
    "statement": "db.query.text",
    "type": "db.system.name",
    "name": {
      "template": "Datastore/statement/${type}/${collection}/${operation}"
    }
  }
}
