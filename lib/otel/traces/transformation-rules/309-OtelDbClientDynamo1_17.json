{
  "name": "OtelDbClientDynamo1_17",
  "type": "db",
  "matcher": {
    "required_span_kinds": [
      "client"
    ],
    "required_attribute_keys": [
      "db.system"
    ],
    "attribute_conditions": {
      "db.system": ["dynamodb"]
    }
  },
  "attributes": [
    {
      "key": "db.system",
      "target": "segment",
      "name": "product"
    },
    {
      "key": "db.name",
      "target": "segment",
      "name": "database_name"
    },
    {
      "template": "dynamodb.${aws.region}.amazonaws.com",
      "target": "segment",
      "name": "host"
    },
    {
      "value": "443",
      "target": "segment",
      "name": "port_path_or_id"
    },
    {
      "template": "arn:aws:dynamodb:${aws.region}:${accountId}:table/${aws.dynamodb.table_names}",
      "target": "segment",
      "name": "cloud.resource_id"
    }
  ],
  "segment": {
    "operation": "db.operation",
    "type": "db.system",
    "name": {
      "template": "Datastore/operation/${type}/${operation}"
    }
  }
}
