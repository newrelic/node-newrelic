{
  "name": "OtelMessagingConsumer1_17",
  "type": "consumer",
  "matcher": {
    "required_span_kinds": [
      "consumer"
    ],
    "required_attribute_keys": [
      "messaging.destination_kind"
    ]
  },
  "attributes": [
    {
      "key": "messaging.destination",
      "target": "trace",
      "name": "message.queueName",
      "highSecurity": true
    },
    {
      "key": "messaging.destination",
      "target": "segment",
      "name": "message.queueName",
      "highSecurity": true
    },
    {
      "key": "net.peer.port",
      "target": "segment",
      "name": "port"
    },
    {
      "key": "net.peer.name",
      "target": "segment",
      "name": "host"
    },
    {
      "key": "messaging.rabbitmq.routing_key",
      "target": "trace",
      "name": "message.routingKey",
      "highSecurity": true
    }
  ],
  "transaction": {
    "type": "message",
    "system": "messaging.system",
    "name": {
      "templateValue": "${messaging.system}/${messaging.destination_kind}/Named/${messaging.destination}"
    }
  }
}
