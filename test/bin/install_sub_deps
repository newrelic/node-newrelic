'use strict'

const path = require('node:path')
const { glob } = require('node:fs/promises')
const util = require('node:util')
const exec = util.promisify(require('child_process').exec)

const options = {
  exclude: (f) => f.includes('test/versioned')
}

let folder
if (process.argv.length > 2) {
  folder = process.argv[2]
}


const retries = 2
async function install(packages, retry) {
  if (!retry) retry = 0

  const failed = []
  let counter = 0
  for (const packageJsonPath of packages) {
    const packagePath = path.resolve(packageJsonPath).split('/').slice(0, -1).join('/')
    console.log('installing deps in ' + packagePath)
    const { stderr } = await exec('cd ' + packagePath + ' && rm -rf node_modules && npm i --no-package-lock', 
      {maxBuffer: 1024 * 500})
    if (isErrorOutput(stderr)) {
      printError(packageJsonPath, stderr)
      if (retry < retries) {
        failed.push(packageJsonPath)
      }
    }

    if (++counter === packages.length) {
      if (failed.length > 0 && retry < retries) {
        console.log('%s package(s) failed to install, retrying...', failed.length)
        await exec('npm cache clean')
        await install(failed, ++retry)
      }
    }
  }
}

// determines if stderr contains errors
function isErrorOutput(text) {
  return (text && text.indexOf('npm ERR') > -1)
}

async function getPackages(folder) {
  if (folder) {
    const commonPackages = await getCommonPackages()
    const packages = await Array.fromAsync(glob(`**/test/${folder}/**/package.json`, options))
    return commonPackages.concat(packages)
  } else {
    const packages = await Array.fromAsync(glob('**/test/**/package.json', options))
    return packages
  }
}

async function getCommonPackages() {
  const packages = await Array.fromAsync(glob('**/test/lib/**/package.json', options))
  packages.unshift('test/package.json', 'test/helpers/package.json')
  return packages
}

function printError(packagePath, error) {
  console.log('-----------------------------------------------------------')
  console.log(packagePath + ' failed installing with the following error:')
  console.log(error)
  console.log('-----------------------------------------------------------')
}

async function main() {
  const packages = await getPackages(folder)
  const correctPackages = packages.filter(function(line) {
    return !/node_modules|example/.test(line)
  })
  await install(correctPackages)
}

main()
