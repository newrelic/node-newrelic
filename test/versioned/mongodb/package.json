{
  "name": "mongodb-tests",
  "comment": "Only tests promise based instrumentation. Callback based instrumentation is tested for v4 of mongodb in `test/version/mongodb-esm` folder",
  "targets": [
    {
      "name": "mongodb",
      "minAgentVersion": "1.32.0"
    }
  ],
  "dockerServices": ["mongodb_5"],
  "version": "0.0.0",
  "private": true,
  "tests": [
    {
      "engines": {
        "node": ">=22"
      },
      "dependencies": {
        "mongodb": ">=4.1.4"
      },
      "files": [
        "aggregation.test.js",
        "bulk.test.js",
        "collection-find.test.js",
        "collection-index.test.js",
        "collection-misc.test.js",
        "collection-update.test.js",
        "cursor.test.js",
        "db.test.js",
        "srv-connect.test.js"
      ]
    }
  ],
  "engines": {
    "node": ">=22"
  }
}
